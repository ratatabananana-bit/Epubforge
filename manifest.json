{
  "manifest_version": 3,
  "name": "EpubForge – Archive Downloader",
  "version": "2.0",
  "description": "Turn any website, web novel, or article into an EPUB — works on Royal Road, FanFiction, Wuxiaworld and more. Cloudflare-resilient with resume, plus a built-in archive download manager. No server.",
  "permissions": ["storage", "unlimitedStorage", "downloads", "activeTab", "scripting", "cookies", "declarativeNetRequest"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "ui/popup.html", "default_title": "EpubForge" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/common.js", "novel/engine.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["lib/common.js", "aa/aa.js"],
      "css": ["aa/aa.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    { "resources": ["ui/dashboard.html"], "matches": ["<all_urls>"] }
  ]
}
